{
  "name": "electron-sqlite-rest-boilerplate",
  "version": "0.0.1",
  "description": "Electron + SQLite + REST API boilerplate for building desktop applications",
  "main": "./out/main/index.js",
  "author": {
    "name": "gpboyer2",
    "email": "773561801qaz@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gpboyer2/electron-sqlite-rest-boilerplate.git"
  },
  "license": "MIT",
  "homepage": "",
  "productName": "Electron SQLite REST",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "copy:server": "node scripts/copy-server.cjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build && npm run copy:server",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "productName": "Electron SQLite REST",
    "appId": "com.electronsqlirest.boilerplate",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "icon": "resources/icons/macos/AppIcon.icns"
    },
    "win": {
      "icon": "resources/app-icon.ico",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-virtual": "^3.13.12",
    "better-sqlite3": "^12.4.6",
    "body-parser": "^1.20.2",
    "cbor-x": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "express": "^4.18.2",
    "log4js": "^6.9.1",
    "lucide-react": "^0.555.0",
    "node-forge": "^1.3.3",
    "serve-favicon": "^2.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.18.6",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^38.1.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "nodemon": "^3.1.11",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  }
}
